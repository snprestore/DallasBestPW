# =============================================================================
# Dallas Best Pressure Washing — environment variables
# Copy this file to `.env.local` and fill in real values.
# Everything here is a PLACEHOLDER. Nothing is hardcoded in the app.
#
# ISOLATION: every ID below must be NEW and dedicated to THIS brand.
# Do NOT reuse Supabase, GTM, GA4, Meta Pixel, or Ads IDs from any other site.
# =============================================================================

# --- Site ---------------------------------------------------------------------
# Absolute base URL, no trailing slash. Used for canonicals, sitemap, OG, schema.
NEXT_PUBLIC_SITE_URL=https://REPLACE-WITH-DOMAIN.com
NEXT_PUBLIC_BUSINESS_NAME=Dallas Best Pressure Washing
# Until the new Google Voice line exists, you may TEMPORARILY paste the existing
# Dallas Best scheduling number here. Format: E.164-ish, digits/spaces ok.
NEXT_PUBLIC_BUSINESS_PHONE=REPLACE_WITH_GOOGLE_VOICE_NUMBER
# Until the new inbox exists, you may TEMPORARILY paste the existing Dallas Best
# scheduling email here.
NEXT_PUBLIC_BUSINESS_EMAIL=REPLACE_WITH_LEAD_EMAIL

# --- Supabase (NEW project — NOT shared with any other business) --------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. Used by the submitLead server action.
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=
# Where new lead notifications are sent. Temporarily the existing scheduling inbox.
LEAD_NOTIFICATION_EMAIL=REPLACE_WITH_LEAD_EMAIL
# Verified Resend sender. Must be on a domain you've verified in Resend.
RESEND_FROM_EMAIL=leads@REPLACE-WITH-DOMAIN.com

# --- Tracking (all NEW, dedicated to this brand) ------------------------------
NEXT_PUBLIC_GTM_ID=GTM-REPLACE
NEXT_PUBLIC_GA4_ID=G-REPLACE
NEXT_PUBLIC_META_PIXEL_ID=REPLACE
